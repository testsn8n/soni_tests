        "jsCode": "// ─── VARIABLES CONFIGURABLES ────────────────────────────────\nconst OFFSET_HORAS = 3; // UTC-3 Argentina\n// ────────────────────────────────────────────────────────────\n\nconst items = $input.all();\nconst hoyMs = Date.now();\n\nconst camposNulos = {\n  \"row_number\": null,\n  \"Nombre \": null,\n  \"Motivo Consulta\": null,\n  \"Numero Whatsapp\": null,\n  \"Fecha Cita\": null,\n  \"Hora Cita\": null,\n  \"Aviso o recordatorio de cita enviado\": null,\n  \"Numero\": null,\n  \"id calendar\": null,\n  \"apikey\": null,\n  \"lid id\": null\n};\n\nconst limpiarFecha = (str) => String(str).replace(/[^\\d\\/\\-]/g, '').trim();\nconst limpiarHora  = (str) => String(str).replace(/[^\\d:]/g, '').trim();\n\nlet cercano = null;\nlet lejano  = null;\nlet menorDiferenciaPasada = Infinity;\nlet menorDiferenciaFutura = Infinity;\n\nfor (let i = 0; i < items.length; i++) {\n  const item     = items[i];\n  const fechaRaw = item.json['Fecha Cita'];\n  const horaRaw  = item.json['Hora Cita'];\n\n  if (!fechaRaw || !horaRaw) continue;\n\n  const fechaStr = limpiarFecha(fechaRaw);\n  const horaStr  = limpiarHora(horaRaw);\n\n  const [dia, mes, anio] = fechaStr.split(/[\\/\\-]/).map(n => parseInt(n, 10));\n  const [hh, mm]         = horaStr.split(':').map(n => parseInt(n, 10));\n\n  if ([dia, mes, anio, hh, mm].some(n => isNaN(n))) continue;\n\n  const fechaMs = Date.UTC(anio, mes - 1, dia, hh + OFFSET_HORAS, mm, 0);\n\n  if (isNaN(fechaMs)) continue;\n\n  const diferencia = Math.abs(hoyMs - fechaMs);\n\n  if (fechaMs < hoyMs) {\n    if (diferencia < menorDiferenciaPasada) {\n      menorDiferenciaPasada = diferencia;\n      cercano = { ...item.json };\n    }\n  } else {\n    if (diferencia < menorDiferenciaFutura) {\n      menorDiferenciaFutura = diferencia;\n      lejano = { ...item.json };\n    }\n  }\n}\n\nreturn [{\n  json: {\n    cercano: cercano ?? camposNulos,\n    lejano:  lejano  ?? camposNulos\n  },\n  pairedItem: { item: 0 }\n}];"
      },
