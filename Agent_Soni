      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  let raw = item.json.output;\n  if (!raw) return { json: {} };\n\n  raw = raw.replace(/```json|```/g, '').trim();\n\n  const lastBrace = raw.lastIndexOf('}');\n  let jsonStr = '';\n\n  if (lastBrace !== -1) {\n    let depth = 0;\n    let start = -1;\n    for (let i = lastBrace; i >= 0; i--) {\n      if (raw[i] === '}') depth++;\n      else if (raw[i] === '{') {\n        depth--;\n        if (depth === 0) { start = i; break; }\n      }\n    }\n    if (start !== -1) jsonStr = raw.substring(start, lastBrace + 1);\n  }\n\n  if (!jsonStr) jsonStr = raw;\n\n  // Intento 1: parseo directo\n  try {\n    return { json: JSON.parse(jsonStr) };\n  } catch(e) {}\n\n  // Intento 2: agregar { al inicio si falta\n  try {\n    return { json: JSON.parse('{' + jsonStr) };\n  } catch(e) {}\n\n  // Intento 3: extraer campos por regex\n  try {\n    const result = {};\n    const regex = /\"([^\"]+)\"\\s*:\\s*\"((?:[^\"\\\\]|\\\\.)*)\"/g;\n    let match;\n    while ((match = regex.exec(jsonStr)) !== null) {\n      result[match[1]] = match[2].replace(/\\\\\"/g, '\"').replace(/\\\\n/g, '\\n');\n    }\n    if (Object.keys(result).length > 0) return { json: result };\n  } catch(e) {}\n\n  return { json: { error: \"No se pudo parsear el JSON\", raw } };\n});"
      },
